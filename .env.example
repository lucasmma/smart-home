# =============================================================================
#  home-server — environment configuration
#  Copy to `.env` and fill in.  `.env` is git-ignored and must never be committed.
#     cp .env.example .env && chmod 600 .env
# =============================================================================

# --- Global -----------------------------------------------------------------
# Timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Sao_Paulo

# User/group the containers run as (match your Ubuntu user: run `id`)
PUID=1000
PGID=1000

# Absolute path to this repo on the Pi. Used by bind mounts.
# e.g. /home/ubuntu/home-server
DATA_ROOT=/home/ubuntu/home-server

# LAN subnet Pi-hole is allowed to answer queries for (CIDR).
# e.g. 192.168.1.0/24
LAN_SUBNET=192.168.1.0/24

# Static LAN IP of the Pi itself (the address you'll point your router's DNS at).
SERVER_IP=192.168.1.10

# =============================================================================
#  Per-service configuration & secrets (grows as services are added)
# =============================================================================

# --- Pi-hole ----------------------------------------------------------------
# Pin the image to a specific release for reproducibility. Check tags at:
#   https://github.com/pi-hole/docker-pi-hole/releases
# Leave as `latest` only if you accept auto-updates on recreate.
PIHOLE_VERSION=2026.06.0
# Admin web UI password. Generate a strong one:
#   openssl rand -base64 18
PIHOLE_PASSWORD=change-me-please

# --- Prometheus -------------------------------------------------------------
# https://github.com/prometheus/prometheus/releases  (e.g. v2.55.1)
PROMETHEUS_VERSION=v3.13.0

# --- Node Exporter ----------------------------------------------------------
# https://github.com/prometheus/node_exporter/releases  (e.g. v1.8.2)
NODE_EXPORTER_VERSION=v1.11.1

# --- cAdvisor ---------------------------------------------------------------
# https://github.com/google/cadvisor/releases  (e.g. v0.49.1)
CADVISOR_VERSION=v0.55.1

# --- Grafana ----------------------------------------------------------------
# https://github.com/grafana/grafana/releases  (e.g. 11.2.0)
GRAFANA_VERSION=13.0.2
GRAFANA_ADMIN_USER=admin
# Generate a strong one: openssl rand -base64 18
GRAFANA_ADMIN_PASSWORD=change-me-please
# Pushover alerting (Grafana). Get both from https://pushover.net
#   USER_KEY: on your dashboard;  TOKEN: create an Application at /apps
PUSHOVER_TOKEN=your-pushover-app-api-token
PUSHOVER_USER_KEY=your-pushover-user-key

# --- Uptime Kuma ------------------------------------------------------------
# Pin to a major (1) or exact tag: https://github.com/louislam/uptime-kuma/releases
UPTIME_KUMA_VERSION=2.4.0

# --- Dozzle -----------------------------------------------------------------
# https://github.com/amir20/dozzle/releases  (e.g. v8.x)
DOZZLE_VERSION=v10.6.7

# --- Speedtest Tracker ------------------------------------------------------
# https://github.com/linuxserver/docker-speedtest-tracker/pkgs/container/speedtest-tracker
SPEEDTEST_VERSION=1.14.5
# REQUIRED Laravel key. Generate with:
#   echo "base64:$(openssl rand -base64 32)"
SPEEDTEST_APP_KEY=base64:CHANGE_ME
# Cron schedule for tests (default hourly). e.g. every 6h: 0 */6 * * *
SPEEDTEST_SCHEDULE=0 * * * *
# Delete results older than N days.
SPEEDTEST_PRUNE_DAYS=90

# --- Homepage ---------------------------------------------------------------
# https://github.com/gethomepage/homepage/releases
HOMEPAGE_VERSION=v1.13.2
# Comma-separated Host headers Homepage will accept. MUST include how you
# reach it. Served on port 80, so the bare IP (no port). Add your Tailscale
# hostname too if you use it, e.g. pi.tailnet-name.ts.net
HOMEPAGE_ALLOWED_HOSTS=localhost:3000,192.168.1.10

# --- Tailscale --------------------------------------------------------------
# https://hub.docker.com/r/tailscale/tailscale/tags
TAILSCALE_VERSION=v1.98.4
# Auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable key for repeatable installs; ephemeral if you prefer.
TAILSCALE_AUTHKEY=tskey-auth-CHANGE_ME
# Name this machine gets in your tailnet.
TAILSCALE_HOSTNAME=home-server
# Optional: advertise LAN subnet to reach OTHER devices remotely (blank = off).
# TAILSCALE_ROUTES=192.168.1.0/24
TAILSCALE_ROUTES=
# Optional extra flags, e.g. --advertise-exit-node
TAILSCALE_EXTRA_ARGS=

