# =============================================================================
#  companion-api — standalone/dev environment
#
#  In the homelab stack these values are supplied by the ROOT .env via
#  compose/companion-api.yml, so you normally DON'T need this file. It's here
#  for running the API on its own during development:
#     cp .env.example .env && npm run dev
# =============================================================================

# HTTP server
PORT=8090
HOST=0.0.0.0
LOG_LEVEL=info

# Optional shared bearer token. Blank => endpoint is open (trusted LAN).
# Must match API_TOKEN in the ESP32 firmware Config.h if set.
API_TOKEN=

# Serve a cached snapshot for this long before refetching sources (ms).
CACHE_TTL_MS=2000
# Per-source HTTP timeout (ms).
SOURCE_TIMEOUT_MS=4000

# --- Prometheus -------------------------------------------------------------
# In-container name on the homelab network; use http://<SERVER_IP>:9090 in dev.
PROM_URL=http://prometheus:9090
DISK_MOUNTPOINT=/
RASPBERRY_UP_JOB=node-exporter
# Optional second host. Blank => `ubuntu` reports false.
#   e.g. up{instance="ubuntu-box:9100"}
UBUNTU_UP_QUERY=

# --- Pi-hole v6 -------------------------------------------------------------
# Pi-hole runs in host-network mode; reach it on the Pi's LAN IP + web port.
# Blank PIHOLE_URL disables the source (adsBlocked/queries stay at last value).
PIHOLE_URL=http://192.168.1.10:8081
PIHOLE_PASSWORD=change-me-please

# --- Speedtest Tracker ------------------------------------------------------
SPEEDTEST_URL=http://speedtest-tracker
# Usually NOT needed: we read the public /api/speedtest/latest endpoint. Only
# set a Sanctum API token (Speedtest UI -> Settings -> API) if you've locked
# that endpoint down.
SPEEDTEST_TOKEN=
# A result older than this (ms) is treated as "internet down". Default 3h.
SPEEDTEST_MAX_AGE_MS=10800000
