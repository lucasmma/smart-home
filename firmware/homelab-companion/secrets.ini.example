; =============================================================================
;  secrets.ini — the firmware's ".env". COPY this file to `secrets.ini` and
;  fill in your values. `secrets.ini` is git-ignored, so real credentials never
;  get committed:
;
;      cp secrets.ini.example secrets.ini
;
;  These become -D build flags; Config.h reads them and falls back to safe
;  placeholders if this file is missing (so the project still compiles).
;  Keep the \" escaping around string values.
; =============================================================================

[secrets]
build_flags =
	-D CFG_WIFI_SSID=\"YOUR_WIFI_SSID\"
	-D CFG_WIFI_PASSWORD=\"YOUR_WIFI_PASSWORD\"
	; The Pi running services/companion-api (no trailing slash):
	-D CFG_API_BASE_URL=\"http://192.168.0.236:8090\"
	; Optional bearer token; leave empty for an open LAN endpoint. Must match
	; COMPANION_API_TOKEN on the backend when set.
	-D CFG_API_TOKEN=\"\"
